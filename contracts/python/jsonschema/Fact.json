{
  "$id": "Fact.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "attribute": {
      "type": "string"
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    },
    "corroboration_count": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "entity_id": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "entity_kind": {
      "enum": [
        "poi",
        "city"
      ],
      "type": "string"
    },
    "id": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "observed_at": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "source_kind": {
      "enum": [
        "llm_research",
        "osm",
        "wikidata",
        "official_site",
        "open_data",
        "advisory",
        "web_review",
        "user_correction"
      ],
      "type": "string"
    },
    "source_url": {
      "anyOf": [
        {
          "format": "uri",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "enum": [
        "active",
        "superseded",
        "disputed",
        "rejected"
      ],
      "type": "string"
    },
    "value": {}
  },
  "required": [
    "id",
    "entity_kind",
    "entity_id",
    "attribute",
    "value",
    "source_url",
    "source_kind",
    "observed_at",
    "confidence",
    "corroboration_count",
    "status"
  ],
  "title": "Fact",
  "type": "object"
}
