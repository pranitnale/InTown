{
  "$id": "TasteProfile.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "anti_preferences": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "budget_tier": {
      "enum": [
        "budget",
        "moderate",
        "comfort",
        "luxury"
      ],
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "dietary": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "hard_exclusions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "id": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "interests": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "pace": {
      "enum": [
        "relaxed",
        "moderate",
        "packed"
      ],
      "type": "string"
    },
    "user_id": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "version": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "id",
    "user_id",
    "version",
    "interests",
    "anti_preferences",
    "hard_exclusions",
    "dietary",
    "budget_tier",
    "pace",
    "created_at"
  ],
  "title": "TasteProfile",
  "type": "object"
}
