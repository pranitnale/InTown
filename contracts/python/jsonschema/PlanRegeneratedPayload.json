{
  "$id": "PlanRegeneratedPayload.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "plan_revision_id": {
      "anyOf": [
        {
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "reason": {
      "enum": [
        "initial",
        "manual_edit",
        "reconfigure",
        "regenerated",
        "go_now",
        "closed_now",
        "restore"
      ],
      "type": "string"
    },
    "trip_city_id": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    }
  },
  "required": [
    "trip_city_id",
    "reason"
  ],
  "title": "PlanRegeneratedPayload",
  "type": "object"
}
