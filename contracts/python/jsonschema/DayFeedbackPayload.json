{
  "$id": "DayFeedbackPayload.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "day_index": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "note": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "rating": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "sentiment": {
      "anyOf": [
        {
          "enum": [
            "positive",
            "neutral",
            "negative"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "trip_city_id": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    }
  },
  "required": [
    "trip_city_id",
    "day_index"
  ],
  "title": "DayFeedbackPayload",
  "type": "object"
}
