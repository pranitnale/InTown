{
  "$id": "AccountExport.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "accounts": {
      "items": {
        "$ref": "AccountLink.json"
      },
      "type": "array"
    },
    "consents": {
      "items": {
        "$ref": "Consent.json"
      },
      "type": "array"
    },
    "sessions": {
      "items": {
        "$ref": "SessionMeta.json"
      },
      "type": "array"
    },
    "taste_profiles": {
      "items": {
        "$ref": "TasteProfile.json"
      },
      "type": "array"
    },
    "traveler_profile": {
      "anyOf": [
        {
          "$ref": "TravelerProfile.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "user": {
      "$ref": "User.json"
    }
  },
  "required": [
    "user",
    "traveler_profile",
    "taste_profiles",
    "consents",
    "accounts",
    "sessions"
  ],
  "title": "AccountExport",
  "type": "object"
}
