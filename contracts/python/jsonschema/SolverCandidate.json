{
  "$id": "SolverCandidate.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "category": {
      "enum": [
        "SIGHT",
        "MUSEUM",
        "VIEWPOINT",
        "PARK_NATURE",
        "ENTERTAINMENT",
        "NIGHTLIFE",
        "SHOPPING",
        "RESTAURANT",
        "CAFE",
        "OTHER"
      ],
      "type": "string"
    },
    "coord": {
      "$ref": "Coordinate.json"
    },
    "est_duration_min": {
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991,
      "type": "integer"
    },
    "indoor_outdoor": {
      "enum": [
        "indoor",
        "outdoor",
        "mixed"
      ],
      "type": "string"
    },
    "must_do": {
      "type": "boolean"
    },
    "node": {
      "type": "string"
    },
    "poi_id": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "priority": {
      "type": "number"
    },
    "windows": {
      "items": {
        "$ref": "SolverOpeningWindow.json"
      },
      "type": "array"
    }
  },
  "required": [
    "poi_id",
    "node",
    "coord",
    "category",
    "est_duration_min",
    "priority",
    "must_do",
    "indoor_outdoor",
    "windows"
  ],
  "title": "SolverCandidate",
  "type": "object"
}
