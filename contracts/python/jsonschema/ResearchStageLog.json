{
  "$id": "ResearchStageLog.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "message": {
      "type": "string"
    },
    "stage": {
      "enum": [
        "brain_check",
        "intake",
        "candidates",
        "ground"
      ],
      "type": "string"
    },
    "type": {
      "const": "stage_log",
      "type": "string"
    }
  },
  "required": [
    "type",
    "stage",
    "message"
  ],
  "title": "ResearchStageLog",
  "type": "object"
}
