    "nodemailer": "^6.10.1",
    "pg": "^8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@supabase/realtime-js": "^2.110.2",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8",
    "jose": "^6.2.3",
    "tsup": "^8",
    "tsx": "catalog:",
